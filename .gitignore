# Microdados brutos (pesados, baixáveis novamente)
data/raw/**
!data/raw/.gitkeep
!data/raw/**/.gitkeep

# Bases intermediárias regeneráveis
data/interim/**
!data/interim/.gitkeep

# Bases processadas regeneráveis (também derivadas dos brutos pelo pipeline)
data/processed/**
!data/processed/.gitkeep

# Outputs entregáveis (PDFs e PPTX) ficam VERSIONADOS — são pequenos
# (< 1 MB cada) e servem como auditoria histórica das entregas. Apenas
# rascunhos com sufixo "_draft" ou "_tmp" são ignorados.
outputs/relatorios/**/*_draft.pdf
outputs/relatorios/**/*_tmp.pdf
outputs/relatorios/**/*_draft.pptx
outputs/relatorios/**/*_tmp.pptx

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
notebooks/scratch/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Claude Code (mantém agents/commands; ignora estado local)
.claude/settings.local.json
.claude/.cache/
